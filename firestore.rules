rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.email == "admin07029@fa-meeting-room.firebaseapp.com" ||
        request.auth.token.email == "admin09267@fa-meeting-room.firebaseapp.com"
      );
    }

    function isBookingOwner(bookingId) {
      return signedIn() &&
        get(/databases/$(database)/documents/bookings/$(bookingId)).data.requesterUid == request.auth.uid;
    }

    match /employees/{employeeCode} {
      // Allows a single code lookup for employee-code login; directory listing is denied.
      allow get: if signedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /bookingHistory/{bookingId} {
      // Explicitly approved: employee-code sessions can view history by employee code.
      allow get, list: if signedIn();
      allow create: if signedIn();
      allow update, delete: if isAdmin() || (
        signedIn() && resource.data.requesterUid == request.auth.uid
      );
    }

    match /publicBookings/{bookingId} {
      allow get, list: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin() || isBookingOwner(bookingId);
    }

    match /bookings/{bookingId} {
      allow get, list: if isAdmin() || (
        signedIn() && (
          resource.data.status == "approved" ||
          resource.data.requesterUid == request.auth.uid
        )
      );

      allow create: if signedIn() &&
        request.resource.data.status == "pending" &&
        request.resource.data.requesterUid == request.auth.uid;

      allow update: if isAdmin() || (
        signedIn() &&
        resource.data.status == "pending" &&
        resource.data.requesterUid == request.auth.uid &&
        request.resource.data.status == "pending" &&
        request.resource.data.requesterUid == resource.data.requesterUid
      );

      allow delete: if isAdmin() || (
        signedIn() &&
        resource.data.requesterUid == request.auth.uid
      );
    }
  }
}