rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.email == "fa@impact.co.th" ||
        request.auth.token.email == "Naruemonc@impact.co.th" ||
        request.auth.token.email == "naruemonc@impact.co.th"
      );
    }

    match /bookings/{bookingId} {
      // Any signed-in user can read approved bookings and their own requests.
      // Admin can read all requests.
      allow get, list: if isAdmin() || (
        signedIn() && (
          resource.data.status == "approved" ||
          resource.data.requesterEmail == request.auth.token.email
        )
      );

      // A user can create only a pending request in their own name.
      allow create: if signedIn() &&
        request.resource.data.status == "pending" &&
        request.resource.data.requesterEmail == request.auth.token.email &&
        request.resource.data.requesterUid == request.auth.uid;

      // Only the two specified Admin accounts can approve, reject, edit, or delete.
      allow update, delete: if isAdmin();
    }
  }
}
