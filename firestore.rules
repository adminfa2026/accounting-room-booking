rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.email == "fa@impact.co.th" ||
        request.auth.token.email == "fagpt123@gmail.com" ||
        request.auth.token.email == "Naruemonc@impact.co.th" ||
        request.auth.token.email == "naruemonc@impact.co.th"
      );
    }

    function isBookingOwner(bookingId) {
      return signedIn() &&
        get(/databases/$(database)/documents/bookings/$(bookingId)).data.requesterEmail == request.auth.token.email &&
        get(/databases/$(database)/documents/bookings/$(bookingId)).data.requesterUid == request.auth.uid;
    }

    match /publicBookings/{bookingId} {
      // This collection contains only availability, never names or meeting details.
      allow get, list: if true;
      allow create, update: if isAdmin();
      // The requester must remove availability first, then remove their booking.
      allow delete: if isAdmin() || isBookingOwner(bookingId);
    }

    match /bookings/{bookingId} {
      allow get, list: if isAdmin() || (
        signedIn() && (
          resource.data.status == "approved" ||
          resource.data.requesterEmail == request.auth.token.email
        )
      );

      allow create: if signedIn() &&
        request.resource.data.status == "pending" &&
        request.resource.data.requesterEmail == request.auth.token.email &&
        request.resource.data.requesterUid == request.auth.uid;

      // The requester may edit only a request that is still pending.
      allow update: if isAdmin() || (
        signedIn() &&
        resource.data.status == "pending" &&
        resource.data.requesterEmail == request.auth.token.email &&
        resource.data.requesterUid == request.auth.uid &&
        request.resource.data.status == "pending" &&
        request.resource.data.requesterEmail == resource.data.requesterEmail &&
        request.resource.data.requesterUid == resource.data.requesterUid
      );

      // The requester can cancel their own booking; Admin can cancel any booking.
      allow delete: if isAdmin() || (
        signedIn() &&
        resource.data.requesterEmail == request.auth.token.email &&
        resource.data.requesterUid == request.auth.uid
      );
    }
  }
}